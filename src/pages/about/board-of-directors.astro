---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Board of Directors" description="Board profiles are now part of the Executive Team page.">
  <section class="bg-[#002147] text-white py-32 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-[#c5a059] text-sm font-bold uppercase tracking-[0.3em] mb-6 block">About Us</span>
      <h1 class="text-4xl md:text-6xl font-serif font-bold mb-8">Board of Directors</h1>
      <p class="text-xl text-white/70 leading-relaxed font-medium mb-10">
        This page has been merged into our leadership page.
      </p>
      <a
        href="/about/executive-team#board-of-directors"
        class="inline-flex bg-[#c5a059] text-[#002147] px-8 py-4 text-xs font-bold uppercase tracking-widest hover:bg-white transition-colors"
      >
        View Board Profiles
      </a>
    </div>
  </section>
</Layout>
