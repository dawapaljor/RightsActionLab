        <h3 class="text-2xl font-serif font-bold text-[#002147] mb-8">
          Choose an Amount
        </h3>
        <div class="grid grid-cols-2 gap-4 mb-8">
          {
            options.map((option) => (
              <button class="p-6 bg-white border border-[#002147]/10 hover:border-[#c5a059] hover:bg-[#002147] hover:text-white transition-all duration-300 text-left group">
                <span class="block text-2xl font-serif font-bold mb-2">
                  {option.amount}
                </span>
                <span class="block text-[10px] uppercase tracking-widest font-bold opacity-60 group-hover:opacity-100">
                  One-time
                </span>
              </button>
            ))
          }
        </div>
        <div class="space-y-6">
          <input
            type="number"
            placeholder="Custom Amount ($)"
            class="w-full bg-white border border-[#002147]/10 px-6 py-4 focus:outline-none focus:border-[#c5a059]"
          />
          <button
            class="w-full bg-[#002147] text-white py-5 font-bold uppercase tracking-widest hover:bg-[#c5a059] transition-all duration-300 shadow-xl flex items-center justify-center gap-3"
          >
            <Heart size={18} fill="currentColor" /> Donate Now
          </button>
        </div>
        <p
          class="text-[10px] text-[#002147]/40 uppercase tracking-widest text-center mt-8 font-bold"
        >
          Secure Payment Powered by Stripe
        </p>
      </div> -->
    </div>
  </section>
</Layout>
