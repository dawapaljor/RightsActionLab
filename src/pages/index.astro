---
import Layout from "../layouts/Layout.astro";
import { ArrowRight, Shield, BookOpen, Users, Cpu } from "lucide-react";

const pillars = [
  {
    title: "Education And Outreach",
    description:
      "Running educational programs on internet freedom, digital security, and strategies of nonviolent advocacy for Tibetans and other communities facing extreme repression.",
    icon: Users,
    img: "/outreach.svg",
  },
  {
    title: "Training",
    description:
      "Providing in-depth training in digital security, civil society organizing, strategic advocacy, and techniques of nonviolent action.",
    icon: Shield,
    img: "/training.svg",
  },
  {
    title: "Research",
    description:
      "Conducting evidence-based research in multiple languages using sound methodologies and secure practices. Our research drives high-impact campaigns.",
    icon: BookOpen,
    img: "/research2-300x257.png",
  },
  {
    title: "Technology Development",
    description:
      "Developing and distributing software that enables secure, private communications for activists, journalists, and others seeking freedom of expression.",
    icon: Cpu,
    img: "/development.svg",
  },
  {
    title: "Building Networks",
    description:
      "Building networks between and capacity of communities facing extreme human rights violations.",
    icon: Cpu,
    img: "/outreach.svg",
  },
];

const projects = [
  {
    name: "Tibet Action Institute",
    description:
      "Combining the power of digital communication with strategic nonviolent action to advance the Tibetan freedom movement",
    image: "logo/tai-logo-hr.svg",
    href: "https://tibetaction.net",
  },
  {
    name: "TIBCERT",
    description:
      "Supporting and strengthening community platforms for digital security and incident response.",
    image: "logo/tibcert-logo.svg",
    href: "https://tibcert.org",
  },
  {
    name: "Convene",
    description:
      "Instant private, ephemeral, and encrypted communication platform in your browser that you can access from anywhere",
    image: "logo/convene.png",
    href: "https://convene.rightsactionlab.org/",
  },
  {
    name: "Guardian Project",
    description:
      "Secure communications, information sharing tools and platforms developed through Rights Action Lab.",
    image: "logo/GuardianProjectLogo.svg",
    href: "https://guardianproject.info/",
  },
];
---

<Layout title="Home" isHome={true}>
  <!-- Hero Section -->
  <section
    class="relative h-[80vh] min-h-[600px] flex items-center overflow-hidden snap-start"
  >
    <div class="absolute inset-0 z-0">
      <img
        src="images/gal-in-twa.jpg"
        alt="Rights Action Lab"
        class="w-full h-full object-cover"
        referrerpolicy="no-referrer"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-[#002147]/90 via-[#002147]/70 to-transparent"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <div class="max-w-2xl">
        <!-- <span class="text-[#c5a059] text-sm font-bold uppercase tracking-[0.3em] mb-6 block">Rights Action Lab</span> -->
        <h1
          class="text-5xl md:text-7xl font-serif font-bold text-white leading-[1.1] mb-8"
        >
          Advancing Rights Through Innovation
        </h1>
        <p
          class="text-xl text-white/80 font-medium leading-relaxed mb-12 max-w-xl"
        >
          Empowering communities facing extreme repression through training,
          research, advocacy and technology development.
        </p>
        <div class="flex flex-wrap gap-6">
          <!-- <a href="/about" class="bg-[#c5a059] text-[#002147] px-8 py-4 font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-xl">
            Our Mission
          </a>
          <a href="#our-projects" class="border-2 border-white/30 text-white px-8 py-4 font-bold uppercase tracking-widest hover:bg-white hover:text-[#002147] transition-all duration-300">
            View Projects
          </a> -->
        </div>
      </div>
    </div>
  </section>
  <!-- Projects Preview -->
  <section class="py-24 px-6 bg-white snap-start" id="our-projects">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <div>
          <h2
            class="text-3xl md:text-5xl font-serif font-bold text-[#002147] mb-8 text-center"
          >
            Rights Action Lab houses mission-aligned projects and fosters
            collaborations:
          </h2>
          <div class="w-24 h-1 bg-[#c5a059] mx-auto mb-12"></div>
          <h4
            class="md:text-5xl font-serif font-bold text-[#002147] text-center pt-20 snap-start scroll-mt-6"
            id="projects"
          >
            Current Projects
          </h4>
        </div>
        <!-- <a href="/projects" class="hidden md:flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-[#002147] hover:text-[#c5a059] transition-colors">
          View All Projects <ArrowRight size={16} />
        </a> -->
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          projects.map((project) => (
            <a
              href={project.href}
              class="group block p-8 bg-[#f5f2ed]/30 border border-[#002147]/10 hover:border-[#c5a059] hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
            >
              <div class="mb-7">
                <div class="w-[190px] h-[64px] flex items-center justify-start">
                  <img
                    src={project.image}
                    alt={project.name}
                    class="w-full h-full object-contain object-left transition-transform duration-300 group-hover:scale-105"
                    referrerpolicy="no-referrer"
                  />
                </div>
              </div>
              <h3 class="text-[32px] leading-[1.15] font-serif font-bold text-[#002147] mb-4 group-hover:text-[#c5a059] transition-colors">
                {project.name}
              </h3>
              <p class="text-[#002147]/65 text-[15px] leading-relaxed font-medium mb-7 min-h-[88px]">
                {project.description}
              </p>
              <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-[#002147] group-hover:text-[#c5a059] transition-colors">
                Learn More <ArrowRight size={14} />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
  <!-- Mission Statement -->
  <section class="py-24 px-6 bg-[#f5f2ed] snap-start">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-[#002147] mb-8">
        Rights Action Lab is a nonprofit 501(c)(3) charitable organization
        dedicated to human rights and digital security.
      </h2>
      <div class="w-24 h-1 bg-[#c5a059] mx-auto mb-12"></div>
      <p class="text-xl text-[#002147]/70 leading-relaxed font-medium">
        We facilitate linkages and support programs that provide education and
        training, research and advocacy, technology development and digital
        security outreach.
      </p>
    </div>
  </section>

  <!-- Pillars -->
  <section class="py-24 px-6 bg-white snap-start">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        {
          pillars.map((pillar, index) => (
            <div
              class={`p-5 bg-[#f5f2ed]/30 border border-[#002147]/10 hover:border-[#c5a059] hover:bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group md:col-span-4 flex flex-col items-center text-center ${index === 3 ? "md:col-start-3" : ""}`}
            >
              <div class="w-34 h-34 flex items-center justify-center ">
                <img
                  src={pillar.img}
                  alt={pillar.title}
                  class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105"
                  referrerpolicy="no-referrer"
                />
              </div>
              <h3 class="text-2xl font-serif font-bold text-[#002147] mb-4 group-hover:text-[#c5a059] transition-colors">
                {pillar.title}
              </h3>
              <p class="text-[#002147]/60 text-sm leading-relaxed font-medium">
                {pillar.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section
    class="py-24 px-6 bg-[#002147] text-white relative overflow-hidden snap-start"
  >
    <div
      class="absolute top-0 right-0 w-1/3 h-full bg-[#c5a059]/10 skew-x-12 translate-x-1/2"
    >
    </div>
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <h2 class="text-4xl md:text-6xl font-serif font-bold mb-8">
        Support Human Rights & Digital Freedom
      </h2>
      <p class="text-xl text-white/70 mb-12 max-w-2xl mx-auto font-medium">
        Your contribution directly supports the development of secure tools and
        strategic training for those on the frontlines of human rights advocacy.
      </p>
      <a
        href="/donate"
        class="inline-block bg-[#c5a059] text-[#002147] px-12 py-5 font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-2xl"
      >
        Support Our Projects
      </a>
    </div>
  </section>
</Layout>
