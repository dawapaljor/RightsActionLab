---
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, ExternalLink } from 'lucide-react';

const features = [
  {
    title: "When They Came to Take Our Child",
    description: "What’s really happening to Tibetan children inside China’s colonial boarding schools? Abuse. Neglect. Indoctrination—a system designed to erase Tibetan identity.",
    image: "http://rightsactionlab.org/wp-content/uploads/2025/07/cbs-banner-wide-e1752056531960.jpg"
  },
  {
    title: "Colonial Boarding School",
    description: "Groundbreaking research into China’s colonial education policies in Tibet show over 78% of students ages six to 18 separated from their families in a vast network of boarding schools.",
    image: "http://rightsactionlab.org/wp-content/uploads/2024/06/CBS.jpg"
  },
  {
    title: "NYT: Ground Breaking Report",
    description: "New York Times investigation finds Tibetan children suffering widespread and systematic physical and psychological harm, cultural erasure in Chinese government-run boarding system.",
    image: "http://rightsactionlab.org/wp-content/uploads/2025/04/UNSTATEMENT.png"
  }
];
---

<Layout title="Tibet Action Institute" description="Combining innovative technology and nonviolent strategies to address rights abuses in Tibet.">
  <!-- Hero -->
  <section class="bg-[#002147] text-white py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-[#c5a059] text-sm font-bold uppercase tracking-[0.3em] mb-6 block">Current Project</span>
        <h1 class="text-5xl md:text-7xl font-serif font-bold mb-8">Tibet Action Institute</h1>
        <p class="text-xl text-white/70 leading-relaxed font-medium">
          Tibet Action Institute uses innovative technology and nonviolent strategies to address human rights abuses in Tibet and around the globe.
        </p>
      </div>
    </div>
  </section>

  <!-- Research Sections -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="space-y-32">
        {features.map((feature, index) => (
          <div class={`flex flex-col lg:flex-row gap-16 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class="flex-1">
              <div class="relative overflow-hidden classic-shadow">
                <img 
                  src={feature.image} 
                  alt={feature.title} 
                  class="w-full aspect-[4/3] object-cover"
                  referrerpolicy="no-referrer"
                />
              </div>
            </div>
            <div class="flex-1 space-y-8">
              <h2 class="text-4xl md:text-5xl font-serif font-bold text-[#002147]">{feature.title}</h2>
              <p class="text-lg text-[#002147]/70 leading-relaxed font-medium">
                {feature.description}
              </p>
              <div class="pt-4">
                <a href="#" class="inline-flex items-center gap-3 text-sm font-bold uppercase tracking-widest text-[#002147] hover:text-[#c5a059] transition-colors">
                  Read the Full Report <ExternalLink size={16} />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="py-24 px-6 bg-[#f5f2ed]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-serif font-bold text-[#002147] mb-8">Driving Global Awareness</h2>
      <p class="text-lg text-[#002147]/70 leading-relaxed font-medium mb-12">
        Our research and campaigns have been featured in major international media outlets, bringing the reality of the situation in Tibet to the attention of policy makers and the public worldwide.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-50 grayscale">
        <div class="flex items-center justify-center font-serif text-2xl font-bold italic">The New York Times</div>
        <div class="flex items-center justify-center font-serif text-2xl font-bold italic">The Guardian</div>
        <div class="flex items-center justify-center font-serif text-2xl font-bold italic">BBC News</div>
        <div class="flex items-center justify-center font-serif text-2xl font-bold italic">Al Jazeera</div>
      </div>
    </div>
  </section>
</Layout>
