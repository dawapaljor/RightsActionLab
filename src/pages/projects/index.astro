---
import Layout from '../../layouts/Layout.astro';
import { ArrowRight } from 'lucide-react';

const projects = [
  {
    name: "Tibet Action Institute",
    description: "Combining innovative technology and nonviolent strategies to address rights abuses in Tibet.",
    image: "https://picsum.photos/seed/tibet/800/600",
    href: "/projects/tibet-action-institute",
    category: "Human Rights"
  },
  {
    name: "Guardian Project",
    description: "Secure communications, information sharing tools and platforms developed through Rights Action Lab.",
    image: "https://picsum.photos/seed/security/800/600",
    href: "/projects/guardian-project",
    category: "Technology"
  },
  {
    name: "TIBCERT",
    description: "Supporting and strengthening community platforms for digital security and incident response.",
    image: "https://picsum.photos/seed/cyber/800/600",
    href: "/projects/tibcert",
    category: "Cybersecurity"
  }
];
---

<Layout title="Our Projects" description="Explore the mission-aligned projects supported by Rights Action Lab.">
  <section class="bg-[#002147] text-white py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <span class="text-[#c5a059] text-sm font-bold uppercase tracking-[0.3em] mb-6 block">Our Work</span>
      <h1 class="text-5xl md:text-7xl font-serif font-bold mb-8">Current Projects</h1>
      <p class="text-xl text-white/70 leading-relaxed font-medium max-w-2xl">
        We house mission-aligned projects and foster collaboration between them to advance human rights and digital security.
      </p>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {projects.map((project) => (
          <a href={project.href} class="group block">
            <div class="relative aspect-[4/3] overflow-hidden mb-8">
              <img 
                src={project.image} 
                alt={project.name} 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                referrerpolicy="no-referrer"
              />
              <div class="absolute top-4 left-4 bg-[#002147] text-white px-4 py-1 text-[10px] uppercase tracking-widest font-bold">
                {project.category}
              </div>
            </div>
            <h3 class="text-3xl font-serif font-bold text-[#002147] mb-4 group-hover:text-[#c5a059] transition-colors">{project.name}</h3>
            <p class="text-[#002147]/60 text-sm leading-relaxed font-medium mb-8">
              {project.description}
            </p>
            <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#002147]">
              Learn More <ArrowRight size={14} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
