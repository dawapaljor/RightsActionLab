---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service">
  <section class="bg-[#002147] text-white py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif font-bold">Terms of Service</h1>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-3xl mx-auto prose prose-slate">
      <p class="text-lg text-[#002147]/70 leading-relaxed font-medium mb-8">
        By using the Rights Action Lab website, you agree to the following terms and conditions.
      </p>
      <h2 class="text-2xl font-serif font-bold text-[#002147] mt-12 mb-4">Use of Content</h2>
      <p class="text-[#002147]/70 mb-6">
        All content on this website is the property of Rights Action Lab unless otherwise noted. You may use our research and reports for educational purposes with proper attribution.
      </p>
      <h2 class="text-2xl font-serif font-bold text-[#002147] mt-12 mb-4">Donations</h2>
      <p class="text-[#002147]/70 mb-6">
        Donations are non-refundable and will be used to support our mission-aligned projects.
      </p>
    </div>
  </section>
</Layout>
