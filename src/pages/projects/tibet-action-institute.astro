---
import Layout from "../../layouts/Layout.astro";
import { ArrowRight, ExternalLink } from "lucide-react";

const features = [
  {
    title: "When They Came to Take Our Child",
    description:
      "What’s really happening to Tibetan children inside China’s colonial boarding schools? Abuse. Neglect. Indoctrination—a system designed to erase Tibetan identity.",
    image: "/images/projects/tai/cbs-report.png",
    url: "https://tibetaction.net/when-they-came-to-take-our-children/",
  },
  {
    title: "Colonial Boarding School",
    description:
      "Groundbreaking research into China’s colonial education policies in Tibet show over 78% of students ages six to 18 separated from their families in a vast network of boarding schools.",
    image: "/images/projects/tai/cbs-2.png",
    url: "https://tibetaction.net/colonial-boarding-school-report/",
  },
  {
    title: "NYT: Ground Breaking Report",
    description:
      "New York Times investigation finds Tibetan children suffering widespread and systematic physical and psychological harm, cultural erasure in Chinese government-run boarding system.",
    image: "/images/projects/tai/NYT-CBS.png",
    url: "https://www.nytimes.com/interactive/2025/01/09/world/asia/tibet-china-boarding-schools.html",
  },
  {
    title: "Lhakar Academy",
    description:
      "Lhakar Academy trains exceptional young Tibetan leaders from from across the globe in Tibet and China’s political context, campaign strategy, resistance tactics, media skills, and secure communication. It equips future leaders with the tools to drive social change, drawing from historic movements like India's independence and the U.S. Civil Rights movement.",
    image: "/images/projects/tai/lhakar.png",
    url: "https://tibetaction.net/peoplepower/",
  },
  {
    title: "Tibet Unlocked Podcast",
    description:
      "Tibet Unlocked breaks through China's information blackout by shining a spotlight on critical issues facing Tibetans in Tibet.",
    image: "/images/projects/tai/tibet-unlocked.png",
    url: "https://open.spotify.com/show/6mQPcoinEcdzxAv4IkaB08",
  },
];
---

<Layout
  title="Tibet Action Institute"
  description="Combining innovative technology and nonviolent strategies to address rights abuses in Tibet."
>
  <!-- Hero -->
  <section class="bg-[#002147] text-white py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row md:items-center gap-8 md:gap-10 justify-between"
      >
        <div class="max-w-3xl">
          <span
            class="text-[#c5a059] text-sm font-bold uppercase tracking-[0.3em] mb-6 block"
            >Current Project</span
          >
          <h1 class="text-5xl md:text-7xl font-serif font-bold mb-8">
            Tibet Action Institute
          </h1>
          <p class="text-xl text-white/70 leading-relaxed font-medium">
            We combine the power of digital communication with strategic
            nonviolent action to advance the Tibetan freedom movement
          </p>
          <div class="w-[190px] h-[80px] flex items-center">
            <img
              src="/logo/tai-logo-hr.svg"
              alt="Tibet Action Institute logo"
              class="w-full h-full object-contain"
              referrerpolicy="no-referrer"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Sections -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          features.map((feature) => (
            <div class="relative aspect-[3/4] overflow-hidden group classic-shadow border border-[#002147]/10 bg-[#002147]/5">
              <img
                src={feature.image}
                alt={feature.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#002147] via-[#002147]/85 to-[#002147]/15 opacity-90 transition-opacity duration-300 group-hover:opacity-95" />

              <div class="absolute inset-0 p-8 flex flex-col justify-end text-white z-10">
                <h3 class="text-2xl font-serif font-bold mb-3 text-[#f5f2ed] group-hover:text-[#c5a059] transition-colors duration-300">
                  {feature.title}
                </h3>
                <p class="text-xs text-[#f5f2ed]/80 leading-relaxed font-medium mb-6 line-clamp-4">
                  {feature.description}
                </p>
                <div class="pt-4 border-t border-[#f5f2ed]/20">
                  <a
                    href={feature.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#c5a059] hover:text-white transition-colors duration-300"
                  >
                    Read More <ExternalLink size={14} />
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="py-24 px-6 bg-[#f5f2ed]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-serif font-bold text-[#002147] mb-8">
        Driving Global Awareness
      </h2>
      <p class="text-lg text-[#002147]/70 leading-relaxed font-medium mb-12">
        Our research and campaigns have been featured in major international
        media outlets, bringing the reality of the situation in Tibet to the
        attention of policy makers and the public worldwide.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-50 grayscale">
        <div
          class="flex items-center justify-center font-serif text-2xl font-bold italic"
        >
          The New York Times
        </div>
        <div
          class="flex items-center justify-center font-serif text-2xl font-bold italic"
        >
          The Guardian
        </div>
        <div
          class="flex items-center justify-center font-serif text-2xl font-bold italic"
        >
          BBC News
        </div>
        <div
          class="flex items-center justify-center font-serif text-2xl font-bold italic"
        >
          Al Jazeera
        </div>
      </div>
    </div>
  </section>
</Layout>
